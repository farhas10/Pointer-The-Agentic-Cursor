## Server
PORT=8787
NODE_ENV=development
LOG_LEVEL=info

## LLM provider
## If no key is set, the server runs with a deterministic MOCK provider
## that streams a canned response (good for client dev without credits).
## Auto-detection order: Anthropic key, then Gemini key, then mock.
## Set LLM_PROVIDER to force a choice (anthropic | gemini | mock).
LLM_PROVIDER=

## Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

## Gemini (Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
## Computer Use automation (preview models only — not gemini-3.5-flash)
GEMINI_AUTOMATION_MODEL=gemini-3-flash-preview

## Auth (Phase 1 ships with a no-op pass-through; this turns on a
## simple shared-secret bearer for testing.)
DEV_SHARED_SECRET=

## Rate limiting (per IP, dev only)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
